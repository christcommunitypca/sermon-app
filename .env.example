# ─────────────────────────────────────────────────────────────────────────────
# .env.local — copy this file to .env.local and fill in real values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Church bootstrap ─────────────────────────────────────────────────────────
# Used ONLY in two places:
#   1. Middleware: to redirect / → /[slug]/dashboard
#   2. auth callback: post-sign-in redirect fallback
# Must match the slug value in the churches table and supabase/seeds/church.sql
NEXT_PUBLIC_CHURCH_SLUG=grace-community

# ── Encryption ────────────────────────────────────────────────────────────────
# Used to encrypt/decrypt AI provider API keys at rest
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=replace-with-32-bytes-of-random-data

# ── AI ────────────────────────────────────────────────────────────────────────
# Which AI provider to use. Valid values: "openai" | "anthropic"
# Default is "openai" if not set.
AI_PROVIDER=anthropic

# Set to "true" to skip real API validation calls for all providers (local dev).
# Set to "false" (or leave unset) when testing with a real API key.
AI_MOCK_VALIDATION=false

# ── Optional: Supabase local dev ─────────────────────────────────────────────
# If using supabase CLI locally, these override the values above:
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<from supabase status>
# SUPABASE_SERVICE_ROLE_KEY=<from supabase status>
